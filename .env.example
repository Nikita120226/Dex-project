# Alchemy Sepolia RPC URL
# Get from: https://dashboard.alchemy.com → Create App → Sepolia → View Key
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Your wallet private key 
# Export from MetaMask: Account → ... → Account Details → Export Private Key
PRIVATE_KEY=your_private_key_here

# Etherscan API Key for contract verification
# Get from: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=your_etherscan_api_key_here
